# ---------------------------------------------------------------------------
# GymBro AI — environment variables.
# Copy to .env.local and fill in. See ENV_SETUP.md for a full walkthrough.
# DO NOT COMMIT real secrets.
# ---------------------------------------------------------------------------

# --- Required ---
JWT_SECRET=                       # random hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
POSTGRES_URL=                     # Postgres connection string (or DATABASE_URL)

# --- Auth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOW_MOCK_AUTH=                  # "true" for local dev without a DB

# --- AI providers (optional; users can also enter keys in the UI) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Nutrition tracking ---
# Open Food Facts (food search + barcode) needs NO key. It enforces per-IP rate
# limits (~15 reads/min, ~10 searches/min); the app rate-limits + caches per user.
# OFF only asks for an identifying User-Agent:
OFF_USER_AGENT=GymBroAI/1.0 (you@example.com)
# Photo meal recognition engine priority:
#   1) LogMeal (optional, paid) if LOGMEAL_API_KEY is set
#   2) OpenAI vision (uses OPENAI_API_KEY above) — the default free* engine
#   3) manual search fallback
# So photo logging works as long as OPENAI_API_KEY is set; LogMeal is optional polish.
LOGMEAL_API_KEY=
LOGMEAL_BASE_URL=                 # optional override, default https://api.logmeal.com
OPENAI_VISION_MODEL=              # optional, default gpt-4o (used for photo meal recognition)

# --- Payments (Razorpay, optional) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_ID_ANALYTICS_MONTHLY=
RAZORPAY_WEBHOOK_SECRET=

# --- Redis cache + rate limiting (optional) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Email (optional) ---
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Admin + misc (optional) ---
ADMIN_USER_IDS=
APP_BASE_URL=http://localhost:3000
DB_ENCRYPTION_KEY=                # 64-char hex enables field-level encryption
